PORT=3000
WEB_ORIGIN=http://localhost:5173

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=erp_crm
DB_PASSWORD=erp_crm
DB_NAME=erp_crm
DB_LOGGING=false

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h

# Shared secret for the platform-onboarding endpoints (POST /api/platform/tenants).
# Only the platform operator should hold this — it's how a new tenant + admin
# user get provisioned before any JWT exists for them.
PLATFORM_ADMIN_KEY=change-me-too

# Optional — override the default admin tenant/user that `npm run seed`
# creates. If unset, defaults to slug "admin", admin@admin.com / Admin123!
SEED_TENANT_SLUG=admin
SEED_TENANT_NAME=Administración
SEED_ADMIN_EMAIL=admin@admin.com
SEED_ADMIN_PASSWORD=Admin123!
SEED_ADMIN_NAME=Administrador
