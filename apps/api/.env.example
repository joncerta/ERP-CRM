PORT=3000
WEB_ORIGIN=http://localhost:5173

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=erp_crm
DB_PASSWORD=erp_crm
DB_NAME=erp_crm
DB_LOGGING=false

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h

# Shared secret for the platform-onboarding endpoints (POST /api/platform/tenants).
# Only the platform operator should hold this — it's how a new tenant + admin
# user get provisioned before any JWT exists for them.
PLATFORM_ADMIN_KEY=change-me-too

# Optional — SMTP server used to actually email a quote to its contact when
# it's sent. If SMTP_HOST is unset, sending is skipped (logged only) so
# local dev/CI don't need real mail credentials.
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=resend
# SMTP_PASS=your-smtp-password
# SMTP_FROM="ERP-CRM <no-reply@tudominio.com>"

# Optional — override the default platform-admin tenant/user that
# `npm run seed` creates (has platform.tenants.manage: sees and manages
# every tenant). If unset, defaults to slug "admin", admin@admin.com / Admin123!
SEED_TENANT_SLUG=admin
SEED_TENANT_NAME=Administración
SEED_ADMIN_EMAIL=admin@admin.com
SEED_ADMIN_PASSWORD=Admin123!
SEED_ADMIN_NAME=Administrador

# Optional — override the default demo customer tenant that `npm run seed`
# creates (an ordinary tenant with the CRM module on, nothing platform-level).
# If unset, defaults to slug "cliente", admin@cliente.com / Cliente123!
SEED_CLIENT_TENANT_SLUG=cliente
SEED_CLIENT_TENANT_NAME=Cliente Demo
SEED_CLIENT_ADMIN_EMAIL=admin@cliente.com
SEED_CLIENT_ADMIN_PASSWORD=Cliente123!
SEED_CLIENT_ADMIN_NAME=Admin Cliente
